# .gitignore kann nur Files ignorieren, die nicht getrackt werden.
# Falls ein File getrackt wird, dann mit "git rm <file>" untracken

# Ordner ignorieren
__pycache__
env
fasterrcnn_model
training_data_opt-in
projects
cloud_projects
bug_reports
node_modules
db.sqlite3
db.sqlite3-wal
db.sqlite3-shm
core/management/commands/Ergebnisse

# Einzelne Datei ignorieren
Notizen_FL.md
Gechäftsmodell.md
scripts/Pläne_Fenstererkennung_loadtest.pdf
scripts/Performance-Vergleich.png


# Alle temporären Dateien ignorieren
*.tmp

